<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> Skill</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    /* Centering the h1 globally */
    h1 {
      text-align: center; /* Center the h1 */
    }

    ul {
      list-style-type: none; /* Remove bullets from unordered list */
      padding-left: 0; /* Optional: Remove default left padding */
    }

    /* Layout for hexagon and content */
    .skill-container {
      display: flex;
      align-items: flex-start;
      justify-content: center; /* Center the content horizontally */
      margin: 20px;
    }

    .svg-wrapper {
      position: relative;
      margin-right: 20px; /* Space between hexagon and other content */
    }

    .hexagon {
      fill: white;
      stroke: black;
      stroke-width: 1px;
    }

    .hexagon-title {
      font-size: 9px;
      font-weight: bold;
      fill: black;
    }

    .hexagon-icon {
      width: 30px;
      height: 30px;
    }

    /* Remove bullets from unordered list */
    ul {
      list-style-type: none;
      padding-left: 0; /* Optional: Remove default left padding */
    }

    /* Additional Styles for Task Checkboxes */
    .task-list input[type="checkbox"] {
      margin-right: 10px;
    }

    .task-list li {
      margin-bottom: 10px;
    }

    /* Content styling */
    .content-wrapper {
      max-width: 600px; /* You can adjust this value */
      text-align: center; /* Centers text content horizontally */
    }

    /* Styles for the text input and button (Initially hidden) */
    .hidden-elements {
      display: none;
      margin-top: 20px;
      text-align: center; /* Centers the input and button */
    }

    .hidden-elements input {
      padding: 10px;
      font-size: 14px;
      margin-bottom: 10px; /* Adds space below the input */
      width: 100%; /* Make input take up full width */
      max-width: 300px; /* Optional: limits max width */
      box-sizing: border-box; /* Ensures padding is included in the width */
    }

    .hidden-elements button {
      padding: 10px 20px;
      font-size: 14px;
      width: 100%; /* Make button take up full width */
      max-width: 300px; /* Optional: limits max width */
      box-sizing: border-box; /* Ensures padding is included in the width */
      background-color: green;
    }

  </style>
</head>
<body>

  <!-- Centered Header -->
  <h1>Skill: <%= title %></h1>

  <!-- Skill container (Hexagon on the left, content on the right) -->
  <div class="skill-container">
    <!-- Hexagon -->
    <div class="svg-wrapper">
      <svg width="100" height="100" viewBox="0 0 100 100">
        <!-- Hexagon Shape -->
        <polygon points="50,5 95,27.5 95,72.5 50,95 5,72.5 5,27.5" class="hexagon" />

        <!-- Title Inside Hexagon (Lowered) -->
        <text x="50%" y="25" class="hexagon-title" text-anchor="middle">
          <% 
            let words = title.split(' ');
            let maxCharsPerLine = 18;  // Max characters per line
            let line = '';
            let dy = 1.2;
            words.forEach((word, index) => {
              line += word + ' ';
              if (line.length > maxCharsPerLine) {
                %>
                <tspan x="50%" dy="<%= dy %>em" font-weight="bold"><%= line.trim() %></tspan>
                <%
                line = '';
                dy += 1.2; // Increase vertical space for next line
              }
            });
            // Add remaining text if any
            if (line) {
              %>
              <tspan x="50%" dy="<%= dy %>em" font-weight="bold"><%= line.trim() %></tspan>
              <%
            }
          %>
        </text>

        <!-- Icon Inside Hexagon (Bottom) -->
        <image x="35%" y="60%" width="30" height="30" href="<%= icon %>" />
      </svg>
    </div>

    <!-- Content (Title, Description, Tasks, etc.) -->
    <div class="content-wrapper">
      <h2>Skill score: <%= score %> points</h2>

      <h2>Description</h2>
      <p><%= description %></p>

      <h2>Tasks To Complete</h2>
      <ul class="task-list">
        <% tasks.forEach(function(task, index) { %>
          <li>
            <label>
              <input type="checkbox" class="task-checkbox" name="task_<%= index %>" <% if (task.completed) { %>checked<% } %> />
              <%= task %>
            </label>
          </li>
        <% }); %>
      </ul>

      <div class="hidden-elements" id="hidden-elements">
        <!-- Hidden elements (text input and button) -->
        <h2>Provide Evidence</h2>
        <input type="text" id="userInput" placeholder="Enter a URL or explanation as evidence for completing this skill" />
        <button id="submitButton">Submit Evidence</button>
      </div>

      <h2>Resources</h2>
      <ul>
        <% resources.forEach(function(resource) { %>
          <li><%= resource %></li>
        <% }); %>
      </ul>

    </div>
  </div>

  <!-- Include Confetti Library -->
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>

  <script>
    // Function to check if all tasks are checked
    function checkAllTasksCompleted() {
      const checkboxes = document.querySelectorAll('.task-checkbox');
      const allChecked = Array.from(checkboxes).every(checkbox => checkbox.checked);

      if (allChecked) {
        // Trigger Confetti Animation
        confetti({
          particleCount: 200,
          spread: 70,
          origin: { y: 0.6 }
        });

        // Show hidden elements (text input and button)
        document.getElementById('hidden-elements').style.display = 'block';
      }
    }

    // Listen to changes in the checkboxes and check if all are checked
    document.querySelectorAll('.task-checkbox').forEach((checkbox) => {
      checkbox.addEventListener('change', checkAllTasksCompleted);
    });
  </script>

</body>
</html>
