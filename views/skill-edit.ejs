<!DOCTYPE html>
<html>
<head>
    <title>Edit Skill</title>
</head>
<style>
    /* Estilos generales */
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f5f5f5;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 100vh;
}

h1 {
    text-align: center;
    color: #333;
    margin-bottom: 20px;
    font-size: 1.8em;
}

/* Estilo del formulario */
form {
    background-color: #ffffff;
    border-radius: 8px;
    padding: 20px 30px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    width: 100%;
    max-width: 500px;
}

label {
    display: block;
    font-weight: bold;
    color: #555;
    margin-bottom: 8px;
    margin-top: 15px;
}

input[type="text"],
input[type="number"],
textarea {
    width: 100%;
    padding: 10px;
    border: 1px solid #ddd;
    border-radius: 5px;
    margin-bottom: 10px;
    font-size: 1em;
    font-family: Arial, sans-serif;
    transition: border-color 0.3s ease;
}

input:focus,
textarea:focus {
    border-color: #007bff;
    outline: none;
}

/* Botón */
button[type="submit"] {
    display: block;
    width: 100%;
    background-color: #007bff;
    color: #ffffff;
    border: none;
    padding: 12px;
    border-radius: 5px;
    font-size: 1em;
    font-weight: bold;
    cursor: pointer;
    transition: background-color 0.3s ease, transform 0.2s ease;
}

button[type="submit"]:hover {
    background-color: #0056b3;
    transform: scale(1.02); /* Efecto de zoom */
}

button[type="submit"]:active {
    background-color: #004085;
    transform: scale(0.98); /* Efecto de clic */
}

/* Ajustes responsivos */
@media (max-width: 768px) {
    form {
        padding: 15px 20px;
    }

    h1 {
        font-size: 1.5em;
    }

    label {
        margin-top: 10px;
    }
}

</style>
<body>
    <h1>Edit Skill in <%= skillTreeName %></h1>
    <form action="/skills/<%= skillTreeName %>/edit/<%= skill._id %>" method="POST">
        <label for="name">Skill Name:</label>
        <input type="text" id="name" name="text" value="<%= skill.text %>" required><br>

        <label for="description">Description:</label>
        <textarea id="description" name="description" required><%= skill.description %></textarea><br>

        <label for="tasks">Tasks (comma-separated):</label>
        <input type="text" id="tasks" name="tasks" value="<%= skill.tasks.join(', ') %>"><br>

        <label for="resources">Resources (comma-separated):</label>
        <input type="text" id="resources" name="resources" value="<%= skill.resources.join(', ') %>"><br>

        <label for="score">Score:</label>
        <input type="number" id="score" name="score" value="<%= skill.score %>" required><br>

        <label for="icon">Icon URL:</label>
        <input type="text" id="icon" name="icon" value="<%= skill.icon %>"><br>

        <button type="submit">Update Skill</button>
    </form>
</body>
</html>
