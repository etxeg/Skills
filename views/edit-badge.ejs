<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Badge</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/messages') %>
    <%- include('partials/username-display') %>
    <h1>Edit Badge</h1>
    <form action="/admin/badges/edit/<%= badge._id %>" method="POST">
        <label for="name">Name:</label>
        <input type="text" id="name" name="name" value="<%= badge.name %>" required>
        <br>
        <label for="bitpoints_min">Min Points:</label>
        <input type="number" id="bitpoints_min" name="bitpoints_min" value="<%= badge.bitpoints_min %>" required>
        <br>
        <label for="bitpoints_max">Max Points:</label>
        <input type="number" id="bitpoints_max" name="bitpoints_max" value="<%= badge.bitpoints_max %>">
        <br>
        <label for="image_url">Image URL:</label>
        <input type="text" id="image_url" name="image_url" value="<%= badge.image_url %>">
        <br>
        <button type="submit">Save</button>
    </form>
    <a href="/admin/badges">Back to Badges</a>
</body>
</html>
