<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About</title>
    <link rel="stylesheet">
</head>

<style>
    /* Estilo general */
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 20px;
    background-color: #f9f9f9;
    color: #333;
    text-align: center;
    line-height: 1.6;
}

h1 {
    font-size: 2em;
    color: #007BFF;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

p {
    font-size: 1.1em;
    color: #555;
    margin: 10px 0;
}

/* Sección de la leyenda */
.legend {
    background-color: #ffffff;
    border: 1px solid #ddd;
    border-radius: 8px;
    padding: 20px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    display: inline-block;
    text-align: left;
    margin-top: 20px;
    max-width: 600px;
}

.legend p {
    font-size: 1em;
    color: #444;
    margin: 8px 0;
}

.legend p span {
    font-size: 1.2em;
    font-weight: bold;
    margin-right: 10px;
}

/* Responsividad */
@media (max-width: 768px) {
    body {
        padding: 15px;
    }

    h1 {
        font-size: 1.5em;
    }

    .legend {
        width: 90%;
        padding: 15px;
    }

    .legend p {
        font-size: 0.95em;
    }
}

</style>

<body>
    <%- include('partials/username-display') %>
    <h1>About</h1>
    <p>Welcome to the About page! This is a guide for the website symbols</p>
    <h1>Legend</h1>
    <p>🔴 = Skill has unverified evidence</p>
    <p>🟢 = Skill has verified evidence</p>
    <p>📒 = View Skill</p>
    <p>✏️ = Edit Skill</p>
</body>
</html>