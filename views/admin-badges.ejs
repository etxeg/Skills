<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Badges</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <%- include('partials/message') %>
    <%- include('partials/username-display') %>
    <h1>Badges</h1>
    <table border="1">
        <thead>
            <tr>
                <th>Name</th>
                <th>Min Points</th>
                <th>Max Points</th>
                <th>Image</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% badges.forEach(badge => { %>
                <tr>
                    <td><%= badge.name %></td>
                    <td><%= badge.bitpoints_min %></td>
                    <td><%= badge.bitpoints_max || 'N/A' %></td>
                    <td><img src="<%= badge.image_url %>" alt="Badge Image" width="50"></td>
                    <td>
                        <a href="/admin/badges/edit/<%= badge._id %>">Edit</a>
                        <form action="/admin/badges/delete/<%= badge._id %>" method="POST" style="display:inline;">
                            <button type="submit">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a href="/admin/dashboard">Back to Dashboard</a>
</body>
</html>
