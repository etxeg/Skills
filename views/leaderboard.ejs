<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Web-Skill Tree: Electronics</title>
    <link rel="stylesheet" href="/css/stylesleaderboard.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/fontawesome/6.0.0-beta3/css/all.min.css">
</head>
<body>
    
    <%- include('partials/username-display') %>
    <h1>Range Explanation</h1>
    <table class="tabla">
        <thead>
            <tr>
                <th>Username</th>
                <th>Score</th>
            </tr>
        </thead>
        <tbody>
            <% if (users && users.length > 0) {%>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.username %></td>
                        <td><%= user.score %></td>
                    </tr>
                <% }); %>
            <% } else { %>    
                <tr>
                    <td colspan="3"> No users found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</body>
</html>
