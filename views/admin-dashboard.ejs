<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<style>
    /* General */
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f5f5f5;
    color: #333;
    text-align: center;
}

h1 {
    font-size: 28px;
    color: #333;
    margin-top: 20px;
}

/* Navegación */
nav {
    margin: 20px 0;
    background-color: #007BFF;
    padding: 10px 0;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
}

nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 20px;
}

nav ul li {
    display: inline;
}

nav ul li a {
    text-decoration: none;
    font-size: 18px;
    font-weight: bold;
    color: #ffffff;
    padding: 10px 20px;
    background-color: #007BFF;
    border-radius: 5px;
    transition: background-color 0.3s ease;
}

nav ul li a:hover {
    background-color: #0056b3;
    color: #ffffff;
}

/* Mensajes */
.message {
    padding: 10px 20px;
    margin: 10px auto;
    max-width: 600px;
    border-radius: 5px;
    font-size: 16px;
    text-align: center;
}

.message-success {
    background-color: #d4edda;
    color: #155724;
    border: 1px solid #c3e6cb;
}

.message-error {
    background-color: #f8d7da;
    color: #721c24;
    border: 1px solid #f5c6cb;
}

/* Botones para usuario (opcional) */
.username-display {
    text-align: center;
    margin: 20px auto;
    font-size: 18px;
    font-weight: bold;
    color: #555;
}

a {
    color: #007BFF;
    text-decoration: none;
}

a:hover {
    color: #0056b3;
}

</style>
<body>
    <%- include('partials/message') %>
    <%- include('partials/username-display') %>
    <h1>Welcome to the Admin Dashboard, <%= username %>!</h1>
    <nav>
        <ul>
            <li><a href="/admin/badges">Manage Badges</a></li>
            <li><a href="/admin/users">Manage Users</a></li>
            <li><a href="/skills">Manage Skills</a></li>
        </ul>
    </nav>
</body>
</html>
