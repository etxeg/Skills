<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Skill Details</title>
    <link rel="stylesheet" href="/css/styles.css">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti"></script> <!-- Add confetti script -->
</head>

<style>
    /* Estilo general */
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    background-color: #f5f5f5;
    color: #333;
    text-align: center;
}

h1 {
    font-size: 2em;
    color: #007BFF;
    margin-top: 20px;
    margin-bottom: 10px;
}

h2 {
    font-size: 1.5em;
    color: #333;
    margin-top: 20px;
    margin-bottom: 10px;
}

p {
    font-size: 1.1em;
    color: #555;
    margin: 10px auto;
    max-width: 600px;
}

/* Listas */
ul {
    list-style: none;
    padding: 0;
    margin: 0 auto 20px;
    max-width: 600px;
    text-align: left;
}

ul li {
    background-color: #ffffff;
    border: 1px solid #ddd;
    padding: 10px;
    margin-bottom: 10px;
    border-radius: 5px;
    transition: background-color 0.3s ease;
}

ul li:hover {
    background-color: #f1f1f1;
}

/* Checkboxes */
input[type="checkbox"] {
    margin-right: 10px;
    transform: scale(1.2);
    cursor: pointer;
}

/* Enlaces */
a {
    text-decoration: none;
    color: #007BFF;
    font-weight: bold;
    margin-top: 20px;
    display: inline-block;
}

a:hover {
    color: #0056b3;
}

/* Hidden elements (feedback form) */
#hidden-elements {
    margin-top: 30px;
    padding: 20px;
    background-color: #e6ffe6;
    border: 2px solid #00c851;
    border-radius: 8px;
    max-width: 600px;
    margin: 30px auto;
    text-align: center;
}

#hidden-elements h3 {
    color: #007BFF;
    margin-bottom: 20px;
}

#hidden-elements input[type="text"] {
    width: 80%;
    padding: 10px;
    margin-bottom: 15px;
    border: 1px solid #ddd;
    border-radius: 5px;
    font-size: 1em;
}

#hidden-elements button {
    background-color: #007BFF;
    color: #ffffff;
    border: none;
    padding: 10px 20px;
    border-radius: 5px;
    font-size: 1em;
    cursor: pointer;
    transition: background-color 0.3s ease;
}

#hidden-elements button:hover {
    background-color: #0056b3;
}

#hidden-elements button:active {
    background-color: #004085;
    transform: scale(0.98);
}

/* Ajustes responsivos */
@media (max-width: 768px) {
    h1, h2 {
        font-size: 1.8em;
    }

    p {
        font-size: 1em;
    }

    ul li {
        padding: 8px;
    }

    #hidden-elements input[type="text"] {
        width: 90%;
    }
}

</style>

<body>
    <%- include('partials/message') %>
        <%- include('partials/username-display') %>
            <h1>
                <%= skill.text %>
            </h1>
            <p>
                <%= skill.description %>
            </p>

            <h2>Tasks</h2>
            <ul>
                <% skill.tasks.forEach((task, index)=> { %>
                    <li>
                        <label>
                            <input type="checkbox" class="task-checkbox" data-index="<%= index %>">
                            <%= task %>
                        </label>
                    </li>
                    <% }) %>
            </ul>

            <h2>Resources</h2>
            <ul>
                <% skill.resources.forEach(resource=> { %>
                    <li><a href="<%= resource %>">
                            <%= resource %>
                        </a></li>
                    <% }) %>
            </ul>

            <a href="/">Back to Skills</a>

            <!-- Hidden elements that will be shown when all tasks are checked -->
            <div id="hidden-elements" style="display: none;">
                <h3>All tasks completed! Great job!</h3>

                <!-- Text input and submit button -->
                <form id="feedback-form" method="POST" action="/skills/<%= skill._id %>/submitUserSkill">
                    <input type="text" id="feedback" name="feedback" placeholder="Enter your feedback..." required>
                    <input type="hidden" id="user-id" name="userId" value="<%= user.username %>">
                    <input type="hidden" id="skill-id" name="skillId" value="<%= skill.id %>">
                    <button type="submit">Submit</button>
                </form>
            </div>

            <script>
                // Function to check if all tasks are checked
                function checkAllTasksCompleted() {
                    const checkboxes = document.querySelectorAll('.task-checkbox');
                    const allChecked = Array.from(checkboxes).every(checkbox => checkbox.checked);

                    if (allChecked) {
                        // Trigger Confetti Animation
                        confetti({
                            particleCount: 200,
                            spread: 70,
                            origin: { y: 0.6 }
                        });

                        // Show hidden elements (text input and button)
                        document.getElementById('hidden-elements').style.display = 'block';
                    }
                }

                // Listen to changes in the checkboxes and check if all are checked
                document.querySelectorAll('.task-checkbox').forEach((checkbox) => {
                    checkbox.addEventListener('change', checkAllTasksCompleted);
                });


                document.getElementById('feedback-form').addEventListener('submit', function (event) {
                    event.preventDefault();

                    const feedback = document.getElementById('feedback').value;
                    const skillId = document.getElementById('skill-id').value;
                    const userId = document.getElementById('user-id').value;

                    // Send the data to the server (AJAX)
                    fetch(`/skills/${skillId}/submitUserSkill`, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                        },
                        body: JSON.stringify({
                            feedback: feedback,
                            skillId: skillId,
                            userId: userId
                        })
                    })
                        .then(response => response.json())
                        .then(data => {
                            alert("Feedback submitted!");
                        })
                        .catch(error => {
                            console.error('Error:', error);
                        });
                });
            </script>
</body>

</html>