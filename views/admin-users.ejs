<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users</title>
  <link rel="stylesheet" href="/css/styles.css">
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      padding: 20px;
      background-color: #f9f9f9;
    }

    h1 {
      text-align: center;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 20px;
    }

    table th, table td {
      border: 1px solid #ddd;
      padding: 8px;
      text-align: center;
    }

    table th {
      background-color: #f4f4f4;
    }

    .action-btn {
      padding: 5px 10px;
      font-size: 14px;
      border: none;
      background-color: #007bff;
      color: #fff;
      border-radius: 4px;
      cursor: pointer;
    }

    .action-btn:hover {
      background-color: #0056b3;
    }

    #passwordForm {
      display: none;
      margin-top: 20px;
    }

    #passwordForm input[type="password"] {
      padding: 8px;
      font-size: 14px;
      width: 200px;
      margin-right: 10px;
    }

    #passwordForm button {
      padding: 8px 12px;
      font-size: 14px;
      border: none;
      background-color: #28a745;
      color: #fff;
      border-radius: 4px;
      cursor: pointer;
    }

    #passwordForm button:hover {
      background-color: #218838;
    }
  </style>
</head>
<body>
  <h1>Manage Users</h1>

  <!-- Tabla de usuarios -->
  <table>
    <thead>
      <tr>
        <th>Username</th>
        <th>Role</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.username %></td>
          <td><%= user.role %></td>
          <td>
            <a href="/admin/users/<%= user.username %>/change-password" class="action-btn">
              Change Password
            </a>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>

  <script>
    // Manejar el clic en "Change Password"
    const changePasswordButtons = document.querySelectorAll('.change-password-btn');
    const passwordForm = document.getElementById('passwordForm');
    const usernameDisplay = document.getElementById('usernameDisplay');
    const userIdInput = document.getElementById('userIdInput');

    changePasswordButtons.forEach(button => {
      button.addEventListener('click', () => {
        const userId = button.getAttribute('data-user-id');
        const username = button.getAttribute('data-username');

        // Mostrar el formulario
        passwordForm.style.display = 'block';

        // Actualizar el formulario con los datos del usuario
        usernameDisplay.textContent = username;
        userIdInput.value = userId;

        // Desplazarse al formulario
        passwordForm.scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>
</body>
</html>
